{
  "manifest_version": 2,
  "name": "Doda Programmable Browser",
  "version": "1.0",
  "description": "Record and replay macros on any page, plus a built-in scripting REPL for browser automation.",
  "permissions": [
    "tabs",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "browser_action": {
    "default_title": "Programmable Browser",
    "default_popup": "recorder/recorder.html",
    "default_icon": "icons/programmable.svg"
  },
  "sidebar_action": {
    "default_title": "Scripting REPL",
    "default_panel": "repl/repl.html",
    "default_icon": "icons/programmable.svg",
    "open_at_install": false
  },
  "icons": {
    "48": "icons/programmable.svg"
  }
}
